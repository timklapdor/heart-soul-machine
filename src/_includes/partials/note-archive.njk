---
layout: /layouts/grid.njk
---
<article class="h-entry blogpost">
	<h1 class="p-name">{{ title }}</h1>

    {% if summary  %}
	<div class="p-summary introduction">
		{{ summary }}
	</div>
	{% endif %}

    	{{ content | safe }}
    
        <div class="note-links">
        <h2>Notes</h2>
            <ul class="notes">
            {% for post in collections.notes | sort(false, false, 'data.title') %}
                <li class="{{post.data.type}}">
                    {%- if post.data.type == "evergreen"-%}{% include "icons/evergreen.svg" %}{%- endif -%}
                    {%- if post.data.type == "seed"-%}{% include "icons/seed.svg" %}{%- endif -%}
                    {%- if post.data.type == "budding"-%}{% include "icons/budding.svg" %}{%- endif -%}
                    <a href="{{ post.url }}">{{post.data.title}}</a></li>
            {% endfor %}
            </ul>
    </div>
</article>